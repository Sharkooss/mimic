{
  "name": "mimic",
  "version": "0.1.0",
  "private": true,
  "description": "Mimic — le jeu de cache-cache artistique multijoueur dans le navigateur.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* build && pnpm -r --filter ./apps/* build",
    "build:shared": "pnpm --filter @mimic/shared build",
    "dev": "pnpm build:shared && pnpm -r --parallel --filter ./apps/* dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\"",
    "db:generate": "pnpm --filter @mimic/server db:generate",
    "db:migrate": "pnpm --filter @mimic/server db:migrate",
    "db:studio": "pnpm --filter @mimic/server db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
