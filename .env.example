# --- Domaine public (pointé vers le VPS, routé par Traefik) -------------------
APP_DOMAIN=mimic.louis-nectoux.fr

# --- Application --------------------------------------------------------------
NODE_ENV=production
# Secret de session/JWT — générer une valeur aléatoire >= 32 caractères :
#   openssl rand -hex 32
APP_SECRET=change-me-with-a-long-random-secret

# --- Base de données PostgreSQL ----------------------------------------------
POSTGRES_DB=mimic
POSTGRES_USER=mimic
POSTGRES_PASSWORD=change-me

# DATABASE_URL est construit automatiquement dans compose.yaml à partir des
# variables POSTGRES_* ci-dessus. En dev local (hors Docker), définir :
# DATABASE_URL=postgresql://mimic:change-me@localhost:5432/mimic
